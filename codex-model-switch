#!/usr/bin/env python3
"""
Codex Model Switch
A CLI tool to quickly switch Codex CLI default model.
Layout and interaction style are aligned with claude-model-switch.
"""

import json
import os
import re
import shutil
import ssl
import sys
import urllib.error
import urllib.request
from urllib.parse import urlsplit

try:  # Python 3.11+
    import tomllib as toml_lib
except ModuleNotFoundError:  # Python 3.10
    try:
        import tomli as toml_lib
    except ModuleNotFoundError:
        print("Missing TOML parser: install `tomli` or use Python 3.11+.")
        sys.exit(1)


CONFIG_FILE = os.path.expanduser("~/.codex/config.toml")
AUTH_FILE = os.path.expanduser("~/.codex/auth.json")
TOOLS_DIR = os.path.expanduser("~/.codex/tools")
INSTALL_DIR = os.path.expanduser("~/.local/bin")
TIMEOUT_SECONDS = 12

# ANSI color codes
RED = '\033[0;31m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
BLUE = '\033[0;34m'
CYAN = '\033[0;36m'
NC = '\033[0m'


def strip_terminal_escape(text):
    """Remove terminal escape sequences from user input."""
    if not isinstance(text, str):
        return ""
    text = re.sub(r'\x1b\[[0-?]*[ -/]*[@-~]', '', text)
    text = text.replace('\x1b', '')
    return text


def normalize_menu_input(text):
    return strip_terminal_escape(text).strip()


def normalize_model_input(text):
    return strip_terminal_escape(text).strip()


def validate_model_name(model):
    if not model:
        return False, "Model name cannot be empty"
    if '"' in model:
        return False, 'Model name cannot contain double quote (")'
    for ch in model:
        code = ord(ch)
        if code < 32 or code == 127:
            return False, "Model name contains control characters"
    return True, ""


def read_text(path):
    with open(path, 'r', encoding='utf-8') as f:
        return f.read()


def load_config_data():
    if not os.path.exists(CONFIG_FILE):
        print(f"{RED}Config file not found: {CONFIG_FILE}{NC}")
        return "", {}

    try:
        raw = read_text(CONFIG_FILE)
        data = toml_lib.loads(raw)
        return raw, data
    except Exception as e:
        print(f"{RED}Failed to parse config: {e}{NC}")
        return "", {}


def load_auth_data():
    if not os.path.exists(AUTH_FILE):
        return {}
    try:
        with open(AUTH_FILE, 'r', encoding='utf-8') as f:
            data = json.load(f)
            if isinstance(data, dict):
                return data
    except Exception:
        pass
    return {}


def dedupe(items):
    seen = set()
    result = []
    for item in items:
        if item not in seen:
            seen.add(item)
            result.append(item)
    return result


def infer_key_candidates(provider):
    p = (provider or "").lower()
    keys = []
    if any(x in p for x in ["openai", "codex", "cliproxy", "oai"]):
        keys.extend(["OPENAI_API_KEY", "OPENAI_AUTH_TOKEN"])
    if any(x in p for x in ["anthropic", "claude"]):
        keys.extend(["ANTHROPIC_AUTH_TOKEN", "ANTHROPIC_API_KEY"])
    if any(x in p for x in ["google", "gemini"]):
        keys.extend(["GOOGLE_API_KEY", "GEMINI_API_KEY"])
    return dedupe(keys)


def resolve_api_key(provider, auth_data):
    provider_keys = infer_key_candidates(provider)
    fallback_keys = [
        "OPENAI_API_KEY",
        "OPENAI_AUTH_TOKEN",
        "ANTHROPIC_AUTH_TOKEN",
        "ANTHROPIC_API_KEY",
        "GOOGLE_API_KEY",
        "GEMINI_API_KEY",
    ]

    for key in provider_keys:
        value = os.environ.get(key)
        if value:
            return value, f"env:{key}"

    for key in provider_keys:
        value = auth_data.get(key)
        if isinstance(value, str) and value:
            return value, f"auth.json:{key}"

    for key, value in auth_data.items():
        if isinstance(value, str) and value and key.upper().endswith(("_API_KEY", "_AUTH_TOKEN")):
            return value, f"auth.json:{key}"

    for key in fallback_keys:
        value = os.environ.get(key)
        if value:
            return value, f"env:{key}"

    return "", ""


def get_provider_info(config_data):
    provider = config_data.get("model_provider", "") if isinstance(config_data, dict) else ""
    providers = config_data.get("model_providers", {}) if isinstance(config_data, dict) else {}

    if not provider or not isinstance(providers, dict):
        return "", "", "", ""

    provider_cfg = providers.get(provider, {})
    if not isinstance(provider_cfg, dict):
        return provider, "", "", ""

    base_url = provider_cfg.get("base_url", "")
    wire_api = provider_cfg.get("wire_api", "")
    model = config_data.get("model", "")

    return str(provider), str(base_url), str(wire_api), str(model)


def extract_origin(url):
    parsed = urlsplit(url)
    if not parsed.scheme or not parsed.netloc:
        return url.rstrip('/')
    return f"{parsed.scheme}://{parsed.netloc}"


def build_model_endpoints(base_url, provider):
    base = base_url.rstrip('/')
    origin = extract_origin(base)
    p = provider.lower()

    endpoints = [f"{base}/models"]
    if not base.endswith('/v1'):
        endpoints.append(f"{base}/v1/models")

    if "anthropic" in p or "claude" in p:
        endpoints.extend([
            f"{origin}/api/provider/anthropic/models",
            f"{origin}/api/provider/anthropic/v1/models",
            f"{origin}/api/provider/claude/models",
            f"{origin}/api/provider/claude/v1/models",
        ])
    else:
        endpoints.extend([
            f"{origin}/api/provider/openai/models",
            f"{origin}/api/provider/openai/v1/models",
            f"{origin}/api/provider/codex/models",
            f"{origin}/api/provider/codex/v1/models",
        ])

    return dedupe(endpoints)


def parse_model_items(items):
    models = []
    for item in items:
        if isinstance(item, str):
            if item.strip():
                models.append(item.strip())
            continue
        if isinstance(item, dict):
            for k in ["id", "model", "name"]:
                v = item.get(k)
                if isinstance(v, str) and v.strip():
                    models.append(v.strip())
                    break
    return dedupe(models)


def parse_model_payload(data):
    if isinstance(data, list):
        return parse_model_items(data)

    if isinstance(data, dict):
        for key in ["data", "models", "items", "result"]:
            value = data.get(key)
            if isinstance(value, list):
                models = parse_model_items(value)
                if models:
                    return models

    return []


def fetch_models(base_url, provider, api_key):
    print(f"{BLUE}Fetching available models...{NC}")

    headers = {'Accept': 'application/json'}
    if api_key:
        headers['Authorization'] = f'Bearer {api_key}'

    ctx = ssl.create_default_context()

    errors = []
    for url in build_model_endpoints(base_url, provider):
        req = urllib.request.Request(url, headers=headers, method='GET')
        try:
            with urllib.request.urlopen(req, timeout=TIMEOUT_SECONDS, context=ctx) as response:
                payload = json.loads(response.read().decode('utf-8', errors='replace'))

            models = parse_model_payload(payload)
            if models:
                return models, url
            errors.append(f"{url}: parsed 0 models")
        except urllib.error.HTTPError as e:
            errors.append(f"{url}: HTTP {e.code}")
        except urllib.error.URLError as e:
            errors.append(f"{url}: {e.reason}")
        except Exception as e:
            errors.append(f"{url}: {e}")

    print(f"{RED}Failed to fetch models{NC}")
    if errors:
        print(f"{YELLOW}" + " | ".join(errors) + f"{NC}")
    return [], ""


def classify_models(models):
    """Classify and sort models alphabetically"""
    gpt_models = sorted([m for m in models if any(x in m.lower() for x in
        ['gpt', 'codex', 'o1', 'o3', 'o4'])])
    claude_models = sorted([m for m in models if any(x in m.lower() for x in
        ['claude', 'haiku', 'sonnet', 'opus', 'minimax']) and m not in gpt_models])
    gemini_models = sorted([m for m in models if 'gemini' in m.lower() and m not in gpt_models and m not in claude_models])
    other_models = sorted([m for m in models if m not in gpt_models and m not in claude_models and m not in gemini_models])

    return gpt_models, claude_models, gemini_models, other_models


def get_current_config():
    """Get current configuration from ~/.codex/config.toml"""
    raw, data = load_config_data()
    if not raw:
        return "", "", "", ""

    provider, base_url, wire_api, model = get_provider_info(data)
    return model, provider, base_url, wire_api


def update_model_in_toml(raw_content, new_model):
    lines = raw_content.splitlines(keepends=True)
    in_top_level = True
    replaced = False

    for i, line in enumerate(lines):
        stripped = line.strip()
        if stripped.startswith('['):
            in_top_level = False
        if not in_top_level:
            continue

        if re.match(r'^\s*model\s*=', line):
            newline = '\n' if line.endswith('\n') else ''
            comment = ''
            before = line.rstrip('\n')
            if '#' in before:
                left, right = before.split('#', 1)
                if '"' in left:
                    comment = f" # {right.strip()}" if right.strip() else ""
                else:
                    comment = f" #{right}" if right else ""
            indent = re.match(r'^(\s*)', line).group(1)
            lines[i] = f'{indent}model = "{new_model}"{comment}{newline}'
            replaced = True
            break

    if not replaced:
        insert_idx = 0
        for i, line in enumerate(lines):
            stripped = line.strip()
            if stripped.startswith('['):
                insert_idx = i
                break
            if re.match(r'^\s*model_provider\s*=', line):
                insert_idx = i + 1
        if lines and insert_idx > 0 and not lines[insert_idx - 1].endswith('\n'):
            lines[insert_idx - 1] += '\n'
        lines.insert(insert_idx, f'model = "{new_model}"\n')

    return ''.join(lines)


def update_model(model):
    """Update main model in ~/.codex/config.toml"""
    model = normalize_model_input(model)
    ok, err = validate_model_name(model)
    if not ok:
        print(f"{RED}{err}{NC}")
        return False

    if not os.path.exists(CONFIG_FILE):
        print(f"{RED}Config file not found: {CONFIG_FILE}{NC}")
        return False

    try:
        raw = read_text(CONFIG_FILE)
        updated = update_model_in_toml(raw, model)
        with open(CONFIG_FILE, 'w', encoding='utf-8') as f:
            f.write(updated)
        return True
    except Exception as e:
        print(f"{RED}Failed to update model: {e}{NC}")
        return False


def sync_to_install_dir():
    """Sync current script and uninstall.sh to ~/.local/bin"""
    script_path = os.path.abspath(__file__)
    script_dir = os.path.dirname(script_path)

    os.makedirs(INSTALL_DIR, exist_ok=True)

    # Copy main script as hidden file
    dest_script = os.path.join(INSTALL_DIR, ".codex-model-switch-bin")
    shutil.copy2(script_path, dest_script)
    os.chmod(dest_script, 0o755)
    print(f"{GREEN}Updated: {dest_script}{NC}")

    # Also keep a direct executable command path in sync
    command_script = os.path.join(INSTALL_DIR, "codex-model-switch")
    shutil.copy2(script_path, command_script)
    os.chmod(command_script, 0o755)
    print(f"{GREEN}Updated: {command_script}{NC}")

    # Copy uninstall script if exists
    uninstall_src = os.path.join(script_dir, "uninstall.sh")
    if os.path.exists(uninstall_src):
        uninstall_dest = os.path.join(INSTALL_DIR, "codex-model-switch-uninstall")
        shutil.copy2(uninstall_src, uninstall_dest)
        os.chmod(uninstall_dest, 0o755)
        print(f"{GREEN}Updated: {uninstall_dest}{NC}")

    # Update Codex tools (regenerate with new paths)
    install_codex_tools()

    print(f"\n{GREEN}Sync complete!{NC}")
    return True


def install_codex_tools():
    """Install Codex tools configuration to ~/.codex/tools"""
    script_path = os.path.abspath(sys.argv[0])
    if script_path.endswith('/'):
        script_path = script_path[:-1]

    os.makedirs(TOOLS_DIR, exist_ok=True)

    tools = {
        "model-list.json": {
            "name": "model-list",
            "description": "List all available models with index numbers",
            "command": ["bash", "-c", f"{script_path} --list"]
        },
        "model.json": {
            "name": "model",
            "description": "Switch model by index number",
            "parameters": {
                "type": "object",
                "properties": {
                    "index": {"type": "integer", "description": "Model index number (see /model-list)"}
                },
                "required": ["index"]
            },
            "command": ["bash", "-c", f"{script_path} ${{index}}"]
        }
    }

    installed = []
    for filename, tool in tools.items():
        filepath = os.path.join(TOOLS_DIR, filename)
        with open(filepath, 'w', encoding='utf-8') as f:
            json.dump(tool, f, indent=2)
        installed.append(filepath)

    print(f"{GREEN}Installed {len(installed)} Codex tools:{NC}")
    for path in installed:
        print(f"  - {path}")
    print(f"{YELLOW}Please restart Codex CLI to use the new tools.{NC}")
    return True


def strip_ansi(text):
    """Remove ANSI escape codes"""
    return re.sub(r'\x1B\[[0-9;]*[mK]', '', text)


def truncate_text(text, max_len):
    """Truncate plain text to max_len using ASCII ellipsis."""
    if max_len <= 0:
        return ""
    if len(text) <= max_len:
        return text
    if max_len <= 3:
        return text[:max_len]
    return text[:max_len - 3] + "..."


def format_model_entry(num, model, current_model, col_width):
    """Format one model line entry; highlight model name only when selected."""
    prefix = f"{num}. "
    max_model_len = max(1, col_width - len(prefix))
    model_display = truncate_text(model, max_model_len)

    if model == current_model:
        entry = f"{prefix}{GREEN}{model_display}{NC}"
    else:
        entry = f"{prefix}{model_display}"

    visible_len = len(prefix) + len(model_display)
    return entry, visible_len


def print_two_columns(items, current_model, start_idx):
    """Display model list in two columns (claude-model-switch style)."""
    if not items:
        return start_idx

    # Calculate column width based on longest item text
    max_len = 0
    for i, item in enumerate(items):
        num = start_idx + i
        item_str = f"{num}. {item}"
        if item == current_model:
            item_str += " *"
        max_len = max(max_len, len(item_str))

    col_width = max_len + 4
    rows = (len(items) + 1) // 2

    for i in range(rows):
        left_idx = i
        right_idx = i + rows if i + rows < len(items) else None

        left = items[left_idx]
        left_selected = (left == current_model)
        left_plain = f"{start_idx + left_idx}. {left}" + (" *" if left_selected else "")
        left_str = f"{GREEN}{left_plain}{NC}" if left_selected else left_plain

        if right_idx is not None:
            right = items[right_idx]
            right_selected = (right == current_model)
            right_plain = f"{start_idx + right_idx}. {right}" + (" *" if right_selected else "")
            right_str = f"{GREEN}{right_plain}{NC}" if right_selected else right_plain

            print(left_str + " " * (col_width - len(strip_ansi(left_str))) + right_str)
        else:
            print(left_str)

    return start_idx + len(items)


def show_menu(gpt_models, claude_models, gemini_models, other_models, config):
    """Display menu"""
    api_display = extract_origin(config[2]) if config[2] else "Not Set"

    print("\n" + GREEN + "=" * 60 + NC)
    print(GREEN + "             Codex CLI Model Switch" + NC)
    print(GREEN + "=" * 60 + NC)
    print("")
    print(f"{YELLOW}API: {api_display}{NC}")
    print("")
    print(f"{YELLOW}Current Configuration:{NC}")
    print(f"  Main Model (model):                {config[0] or 'Not Set'}")
    print(f"  Provider (model_provider):         {config[1] or 'Not Set'}")
    print(f"  Wire API:                          {config[3] or 'Not Set'}")
    print("")

    idx = 1

    if gpt_models:
        print(f"{BLUE}--- GPT/Codex Models ({len(gpt_models)}) ---{NC}")
        idx = print_two_columns(gpt_models, config[0], idx)
        print("")

    if claude_models:
        print(f"{BLUE}--- Claude Compatible Models ({len(claude_models)}) ---{NC}")
        idx = print_two_columns(claude_models, config[0], idx)
        print("")

    if gemini_models:
        print(f"{BLUE}--- Google Gemini Models ({len(gemini_models)}) ---{NC}")
        idx = print_two_columns(gemini_models, config[0], idx)
        print("")

    if other_models:
        print(f"{BLUE}--- Other Models ({len(other_models)}) ---{NC}")
        idx = print_two_columns(other_models, config[0], idx)
        print("")

    print(f"{CYAN}--- Set Individual Models ---{NC}")
    print("  [m] Set Main Model (model)")
    print("")
    print(f"{CYAN}--- Batch Operations ---{NC}")
    print("  [a] Custom model name input")
    print("  [r] Refresh model list")
    print("  [u] Sync scripts to ~/.local/bin")
    print("  [q] Quit")
    print("")


def select_model_menu(gpt_models, claude_models, gemini_models, other_models, target_name):
    """Model selection submenu"""
    print(f"\n{target_name} Model Selection:")
    all_models = gpt_models + claude_models + gemini_models + other_models
    for idx, model in enumerate(all_models, 1):
        print(f"  {idx}. {model}")
    print("  [q] Back")
    choice = normalize_menu_input(input("Choose: "))
    if choice.isdigit() and 1 <= int(choice) <= len(all_models):
        return all_models[int(choice) - 1]
    return None


def list_models_json(models):
    """List all models in JSON format for tools"""
    result = {"models": [{"id": m} for m in models]}
    print(json.dumps(result))


def switch_model_by_index(index, models):
    """Switch model by index number"""
    try:
        idx = int(index)
        if idx < 1 or idx > len(models):
            print(f'{{"error": "Invalid index. Available range: 1-{len(models)}"}}')
            return

        selected_model = models[idx - 1]
        if update_model(selected_model):
            print(json.dumps({
                "success": True,
                "model": selected_model,
                "message": f"Model switched to {selected_model}."
            }))
    except ValueError:
        print('{"error": "Invalid index. Please provide a number."}')


def print_help():
    print("Usage: codex-model-switch [OPTIONS] [INDEX]")
    print("")
    print("Options:")
    print("  -l, --list         List all models (JSON format)")
    print("  -u, --update       Sync scripts to ~/.local/bin")
    print("  --set MODEL        Set model directly by model id")
    print("  --show-config      Show resolved codex config")
    print("  INDEX              Switch to model by index number")
    print("  -h, --help         Show this help message")


def main():
    if not sys.version_info >= (3, 7):
        print(f"{RED}Python 3.7+ required{NC}")
        sys.exit(1)

    raw_config, config_data = load_config_data()
    if not raw_config:
        sys.exit(1)

    provider, base_url, wire_api, current_model = get_provider_info(config_data)
    if not provider or not base_url:
        print(f"{RED}Invalid ~/.codex/config.toml: missing model_provider or provider base_url{NC}")
        sys.exit(1)

    auth_data = load_auth_data()
    api_key, key_source = resolve_api_key(provider, auth_data)

    # Parse command line arguments (keep layout close to claude-model-switch)
    if len(sys.argv) > 1:
        arg = sys.argv[1]

        if arg in ['--list', '-l', '--list-json']:
            models, _ = fetch_models(base_url, provider, api_key)
            if not models:
                print('{"error": "Failed to fetch models"}')
                return

            gpt_models, claude_models, gemini_models, other_models = classify_models(models)
            sorted_models = gpt_models + claude_models + gemini_models + other_models
            list_models_json(sorted_models)
            return

        if arg in ['--update', '-u', '--sync']:
            print(f"{BLUE}Syncing scripts to {INSTALL_DIR}...{NC}")
            sync_to_install_dir()
            return

        if arg in ['--help', '-h']:
            print_help()
            return

        if arg == '--show-config':
            print(f"config_file={CONFIG_FILE}")
            print(f"auth_file={AUTH_FILE}")
            print(f"provider={provider}")
            print(f"base_url={base_url}")
            print(f"wire_api={wire_api or '(not set)'}")
            print(f"current_model={current_model or '(not set)'}")
            print(f"api_key_source={key_source or '(none)'}")
            return

        if arg == '--set':
            if len(sys.argv) < 3:
                print('{"error": "Missing model id for --set"}')
                return
            model_id = normalize_model_input(sys.argv[2])
            ok, err = validate_model_name(model_id)
            if not ok:
                print(json.dumps({"error": err}))
                return
            if update_model(model_id):
                print(json.dumps({"success": True, "model": model_id, "message": f"Model switched to {model_id}."}))
            return

        if arg.isdigit():
            models, _ = fetch_models(base_url, provider, api_key)
            if not models:
                print('{"error": "Failed to fetch models"}')
                return
            gpt_models, claude_models, gemini_models, other_models = classify_models(models)
            sorted_models = gpt_models + claude_models + gemini_models + other_models
            switch_model_by_index(arg, sorted_models)
            return

        print_help()
        return

    # Interactive mode
    model_list_tool = os.path.join(TOOLS_DIR, "model-list.json")
    model_tool = os.path.join(TOOLS_DIR, "model.json")
    if not (os.path.exists(model_list_tool) and os.path.exists(model_tool)):
        print(f"{YELLOW}Installing Codex tools...{NC}")
        install_codex_tools()
        print("")

    all_models, used_url = fetch_models(base_url, provider, api_key)
    if not all_models:
        print(f"{RED}Failed to fetch models, exiting{NC}")
        sys.exit(1)

    if key_source:
        print(f"{CYAN}Auth source: {key_source}{NC}")
    print(f"{GREEN}Found {len(all_models)} models{NC}")

    gpt_models, claude_models, gemini_models, other_models = classify_models(all_models)
    config = get_current_config()

    while True:
        show_menu(gpt_models, claude_models, gemini_models, other_models, config)
        choice = normalize_menu_input(input("Enter option: "))

        all_model_list = gpt_models + claude_models + gemini_models + other_models

        if choice.isdigit() and 1 <= int(choice) <= len(all_model_list):
            idx = int(choice) - 1
            selected_model = all_model_list[idx]
            print(f"\nSelected model: {selected_model}")
            print("  [1] Set Main Model (model)")
            print("  [q] Back")
            sub_choice = normalize_menu_input(input("Choose: ")).lower()
            if sub_choice == '1':
                if update_model(selected_model):
                    print(f"{GREEN}Set Main Model to: {selected_model}{NC}")
            config = get_current_config()

        elif choice.lower() == 'm':
            selected = select_model_menu(gpt_models, claude_models, gemini_models, other_models, "Main")
            if selected and update_model(selected):
                print(f"{GREEN}Set Main Model to: {selected}{NC}")
                config = get_current_config()

        elif choice.lower() == 'a':
            custom_model = normalize_model_input(input("Enter model name: "))
            ok, err = validate_model_name(custom_model)
            if not ok:
                print(f"{RED}{err}{NC}")
                input("\nPress Enter to continue...")
                continue
            if update_model(custom_model):
                print(f"{GREEN}Set model to: {custom_model}{NC}")
            config = get_current_config()

        elif choice.lower() == 'r':
            all_models, used_url = fetch_models(base_url, provider, api_key)
            if all_models:
                gpt_models, claude_models, gemini_models, other_models = classify_models(all_models)
                print(f"{GREEN}Refreshed models ({len(all_models)}) from: {used_url}{NC}")
            else:
                print(f"{RED}Failed to refresh models{NC}")
            config = get_current_config()

        elif choice.lower() == 'u':
            sync_to_install_dir()

        elif choice.lower() == 'q':
            print("Goodbye!")
            break

        else:
            print(f"{RED}Invalid option{NC}")

        input("\nPress Enter to continue...")


if __name__ == "__main__":
    main()
